# --- API ---
API_HOST=0.0.0.0
API_PORT=8080

# --- Database ---
POSTGRES_URL=postgres://courseassistant:courseassistant@localhost:5432/courseassistant?sslmode=disable
REDIS_URL=redis://localhost:6379

# --- Object storage ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Auth ---
JWT_SIGNING_KEY=your-secret-key-change-in-production
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_LARGE_MODEL=gpt-4o
OPENAI_LLM_MINI_MODEL=gpt-4o-mini

# --- Providers ---
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
RERANKER_PROVIDER=openai
GUARDRAIL_PROVIDER=openai

# --- Feature flags ---
GUARDRAILS_ENABLED=true
EVALUATOR_ENABLED=true
MAX_RETRIES=3
EVALUATOR_THRESHOLD=7.0

# --- Service environment ---
SERVICE_ENV=development
MIGRATIONS_PATH=migrations