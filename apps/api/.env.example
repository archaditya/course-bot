# See docs/09-deployment.md#configuration-strategy — names only, no real secrets.

SERVICE_ENV=local
API_ADDR=:8080

# --- Database ---
POSTGRES_URL=postgres://courseassistant:courseassistant@localhost:5432/courseassistant?sslmode=disable
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO locally, real R2 in staging/prod) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=courseassistant
R2_SECRET_ACCESS_KEY=courseassistant
R2_BUCKET=course-assistant-dev

# --- Vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Auth ---
JWT_SIGNING_KEY=dev-only-change-me
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Providers (see docs/02-system-architecture.md#provider-abstraction) ---
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
RERANKER_PROVIDER=openai
GUARDRAIL_PROVIDER=openai

# --- Feature flags ---
GUARDRAILS_ENABLED=true
MAX_EVALUATOR_RETRIES=3
